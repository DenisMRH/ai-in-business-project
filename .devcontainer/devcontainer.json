{
    "name": "Isolated Cursor Environment",
    "image": "mcr.microsoft.com/devcontainers/python:3.11",
    "remoteUser": "root",
    "updateRemoteUserUID": false,
    "features": {
        "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {
            "version": "latest",
            "enableNonRootDocker": "true",
            "moby": "true"
        }
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python"
            ]
        }
    }
}